model user_ip_addresses {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  ip_address String    @db.Inet
  label      String?
  is_trusted Boolean?  @default(true)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_ip_addresses_user")

  @@index([ip_address], map: "idx_user_ip_addresses_ip")
  @@index([user_id], map: "idx_user_ip_addresses_user_id")
}

model user_jellyfin_config {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String   @unique @db.Uuid
  server_url        String
  api_key           String
  jellyfin_user_id  String
  sync_enabled      Boolean  @default(true)
  webhook_secret    String   @default(dbgenerated("(gen_random_uuid())::text"))
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)
  jellyfin_username String?
  users             users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id                                              String                @id @db.Uuid
  created_at                                      DateTime              @default(now()) @db.Timestamptz(6)
  username                                        String?
  name                                            String?
  email                                           String?
  image_url                                       String?
  tmdb_id                                         String?
  bio                                             String?               @default("Go to settings to change your Bio")
  backdrop_url                                    String?               @default("https://w0.peakpx.com/wallpaper/939/963/HD-wallpaper-technology-error-404-not-found-black-white-minimalist.jpg")
  feed_genres                                     Json[]
  premium                                         Boolean               @default(false)
  email_verified                                  Boolean               @default(true)
  updated_at                                      DateTime              @default(now()) @updatedAt @db.Timestamptz(6)
  comment_likes                                   comment_likes[]
  comments                                        comments[]
  dev_blog                                        dev_blog[]
  follows_follows_following_idTousers             follows[]             @relation("follows_following_idTousers")
  follows_follows_user_idTousers                  follows[]             @relation("follows_user_idTousers")
  likes                                           likes[]
  movie_genre_stats                               movie_genre_stats?
  new_episodes                                    new_episodes[]
  notifications_notifications_recipient_idTousers notifications[]       @relation("notifications_recipient_idTousers")
  notifications_notifications_triggered_byTousers notifications[]       @relation("notifications_triggered_byTousers")
  posts                                           posts[]
  saves                                           saves[]
  tv_genre_stats                                  tv_genre_stats?
  user_ip_addresses                               user_ip_addresses[]
  user_jellyfin_config                            user_jellyfin_config?
  watch_history                                   watch_history[]
  watch_list                                      watch_list[]
  accounts                                        account[]
  sessions                                        session[]

  @@index([id])
}

// ── Better Auth tables (auth identity/session store) ──────────────────
model account {
  id                    String    @id @db.Uuid
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id") @db.Uuid
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz(6)
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz(6)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                  users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model session {
  id        String   @id @db.Uuid
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  token     String   @unique
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model verification {
  id         String   @id @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([identifier])
  @@map("verification")
}

model watch_history {
  id                 String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id            String    @db.Uuid
  media_type         String
  media_id           Int
  season_number      Int?
  episode_number     Int?
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
  time_spent         Int?
  percentage_watched String?
  hidden_until       DateTime? @db.Timestamptz(6)
  sync_source        String    @default("app")
  playback_position  Int?
  users              users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, media_type, media_id, season_number, episode_number], map: "watch_history_unique")
  @@index([user_id, created_at(sort: Desc)], map: "idx_watch_history_user_created_desc")
  @@index([user_id, media_type, media_id, season_number, episode_number], map: "idx_watch_history_user_media_lookup")
  @@index([user_id])
  @@index([user_id, media_type, media_id, season_number, episode_number])
}

model watch_list {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  user_id         String?  @db.Uuid
  media_type      String?
  media_id        BigInt?
  watch_list_type String?
  users           users?   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, media_type, media_id, watch_list_type])
}
